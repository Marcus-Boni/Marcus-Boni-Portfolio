# ─── Firebase (admin + analytics) ──────────────────────────────────────────
# Create a project at https://console.firebase.google.com, add a Web App, and
# copy its config values here. Without these, the public site still runs on the
# static data in src/data/profile.ts and the /admin area stays in demo mode.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
