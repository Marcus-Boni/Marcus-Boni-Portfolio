# Netlify cache headers.
# Everything under /assets/ carries a content hash in its filename, so it can
# be cached forever — a new deploy produces new filenames.

/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Stable-name static files: cache for a week, revalidate in the background.
/portrait-320.webp
  Cache-Control: public, max-age=604800, stale-while-revalidate=86400
/portrait-640.webp
  Cache-Control: public, max-age=604800, stale-while-revalidate=86400
/og-image.png
  Cache-Control: public, max-age=604800, stale-while-revalidate=86400
/favicon.svg
  Cache-Control: public, max-age=604800, stale-while-revalidate=86400
/marcus-boni-cv.pdf
  Cache-Control: public, max-age=86400, stale-while-revalidate=86400
